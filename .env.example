# Research Institute Website - Environment Configuration

# Server
NODE_ENV=production
PORT=3000

# JWT
JWT_SECRET=your-secure-secret-key-here-change-in-production

# Database (when upgrading from mock database)
DATABASE_URL=your-database-connection-string

# Azure Storage (optional, for file uploads to Azure Blob Storage)
AZURE_STORAGE_CONNECTION_STRING=your-storage-connection-string
AZURE_STORAGE_CONTAINER_NAME=research-uploads

# Email Service (for notifications)
SENDGRID_API_KEY=your-sendgrid-api-key
NOTIFICATION_EMAIL=admin@researchinstitute.org

# Authentication
AUTH_PROVIDER=local # or 'azure-ad'
AZURE_AD_CLIENT_ID=your-azure-ad-client-id
AZURE_AD_CLIENT_SECRET=your-azure-ad-client-secret
AZURE_AD_TENANT_ID=your-azure-ad-tenant-id
